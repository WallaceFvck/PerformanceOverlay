<Window x:Class="PerformanceOverlay.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PerformanceOverlay — Settings"
        Width="480" Height="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/overlay.ico"
        Background="#1A1A1A" Foreground="White">

    <Window.Resources>
        <!-- ═══ Paleta base ═══ -->
        <SolidColorBrush x:Key="CtrlBg" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="CtrlBorder" Color="#444444"/>
        <SolidColorBrush x:Key="CtrlHover" Color="#E53935"/>
        <SolidColorBrush x:Key="CtrlHoverBg" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="PanelBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SepBrush" Color="#333333"/>

        <!-- ═══ TextBlock ═══ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ═══ TextBox ═══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CtrlBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CtrlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ═══ TabControl — sem borda, fundo escuro ═══ -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ═══ TabItem — estilo dark idêntico aos controles ═══ -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBd" Background="{StaticResource CtrlBg}"
                                BorderBrush="{StaticResource CtrlBorder}"
                                BorderThickness="1" CornerRadius="3,3,0,0"
                                Padding="16,8" Margin="0,0,2,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Cp" ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBd" Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="TabBd" Property="BorderBrush" Value="#E53935"/>
                                <Setter TargetName="TabBd" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBd" Property="BorderBrush" Value="#E53935"/>
                                <Setter Property="Foreground" Value="#DDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ HotkeyButton ═══ -->
        <Style x:Key="HotkeyButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CtrlBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CtrlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CtrlHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ComboBox ToggleButton (seta) ═══ -->
        <Style x:Key="CbxToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource CtrlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CtrlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="Transparent"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CtrlHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CtrlHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ComboBox — visual idêntico ao HotkeyButton ═══ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CtrlBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CtrlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Style="{StaticResource CbxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="10,6,28,6"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent" Foreground="White"
                                     FontFamily="Consolas" FontSize="13"
                                     BorderThickness="0" Padding="10,6,28,6"
                                     CaretBrush="White"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Center" Focusable="True"/>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                                <Border Background="#222" BorderBrush="#444" BorderThickness="1"
                                        CornerRadius="3" Margin="0,2,0,0" Padding="2"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ComboBoxItem ═══ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Botões ═══ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#E53935"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl>
            <!-- ═══ ABA GERAL ═══ -->
            <TabItem x:Name="TabGeneral" Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="TxtManualTitle" Text="Manual Monitoring" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtManualDesc" Text="" Foreground="#999" FontSize="11" Margin="0,0,0,4"/>

                        <!-- Processo: ComboBox editável + botão refresh -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CbxProcesses"/>
                            <Button Grid.Column="1" Content="↻" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" Margin="6,0,0,0" Click="OnRefreshProcesses"/>
                        </Grid>
                        <TextBlock x:Name="TxtManualHint" Text="" Foreground="#666" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtProcessFeedback" Text="" Foreground="#4CAF50" FontSize="11" Margin="0,4,0,0"/>

                        <Separator Background="{StaticResource SepBrush}" Margin="0,14,0,14"/>

                        <!-- Hotkeys -->
                        <TextBlock x:Name="TxtHotkeysTitle" Text="Hotkeys" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtHotkeysDesc" Text="" Foreground="#999" FontSize="11" Margin="0,0,0,8"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtHkToggleLabel" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyToggle" Grid.Column="1" Style="{StaticResource HotkeyButton}" Content="F8"
                                    Click="OnHotkeyButtonClick" PreviewKeyDown="OnHotkeyKeyDown" LostFocus="OnHotkeyLostFocus"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtHkPositionLabel" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyPosition" Grid.Column="1" Style="{StaticResource HotkeyButton}" Content="Ctrl+F8"
                                    Click="OnHotkeyButtonClick" PreviewKeyDown="OnHotkeyKeyDown" LostFocus="OnHotkeyLostFocus"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtHkModeLabel" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyMode" Grid.Column="1" Style="{StaticResource HotkeyButton}" Content="Shift+F8"
                                    Click="OnHotkeyButtonClick" PreviewKeyDown="OnHotkeyKeyDown" LostFocus="OnHotkeyLostFocus"/>
                        </Grid>
                        <TextBlock x:Name="TxtHotkeyStatus" Foreground="#FF9800" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

                        <Separator Background="{StaticResource SepBrush}" Margin="0,14,0,14"/>

                        <!-- Idioma -->
                        <TextBlock x:Name="TxtLanguageTitle" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbxLanguage" HorizontalAlignment="Left" MinWidth="260"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ ABA APARÊNCIA ═══ -->
            <TabItem x:Name="TabAppearance" Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="TxtAccentTitle" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <WrapPanel Margin="0,0,0,8">
                            <Button Background="#E53935" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#2196F3" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#4CAF50" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#9C27B0" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#FF9800" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#00BCD4" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                            <Button Background="#EEEEEE" Width="32" Height="32" Margin="0,0,6,0" Click="OnColorPick" BorderThickness="0" Cursor="Hand"/>
                        </WrapPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtHexLabel" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtAccentHex" Grid.Column="1" TextChanged="OnHexChanged"/>
                        </Grid>

                        <Separator Background="{StaticResource SepBrush}" Margin="0,16,0,16"/>

                        <TextBlock x:Name="TxtScaleTitle" FontWeight="SemiBold" FontSize="14"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SliderScale" Minimum="0.5" Maximum="2.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnScaleChanged"/>
                            <TextBlock x:Name="TxtScaleValue" Grid.Column="1" Text="1.0x" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="{StaticResource SepBrush}" Margin="0,12,0,12"/>

                        <TextBlock x:Name="TxtOpacityTitle" FontWeight="SemiBold" FontSize="14"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SliderOpacity" Minimum="0.1" Maximum="1.0" Value="0.92" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnOpacityChanged"/>
                            <TextBlock x:Name="TxtOpacityValue" Grid.Column="1" Text="92%" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="{StaticResource SepBrush}" Margin="0,14,0,14"/>

                        <TextBlock x:Name="TxtInitialMode" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbxInitialMode" HorizontalAlignment="Left" MinWidth="260">
                            <ComboBoxItem x:Name="CbxModeFullItem" Tag="Full" IsSelected="True"/>
                            <ComboBoxItem x:Name="CbxModeCompactItem" Tag="Compact"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnCancel"/>
            <Button x:Name="BtnSave" Style="{StaticResource PrimaryButton}" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
